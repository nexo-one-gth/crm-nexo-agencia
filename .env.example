# ─── Google Drive (Módulo Recursos) ─────────────────────────────────────────
# Email del service account (Google Cloud Console > IAM > Service Accounts)
GOOGLE_SERVICE_ACCOUNT_EMAIL=nexo-drive@<project-id>.iam.gserviceaccount.com

# Clave privada del service account (copiá el campo "private_key" del JSON descargado)
# Las \\n deben reemplazarse por saltos de línea reales, o dejar como \\n en .env.local
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"

# ID de la carpeta raíz compartida con el service account (extraelo de la URL de Drive)
# Ejemplo: https://drive.google.com/drive/folders/<FOLDER_ID>
GOOGLE_DRIVE_ROOT_FOLDER_ID=<folder-id>

# ─── Supabase ───────────────────────────────────────────────────────────────
# URL del proyecto (visible en: Supabase Dashboard > Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co

# Anon key (pública, va al bundle del cliente)
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# Service Role key — NUNCA exponer al cliente. Solo server-side.
# Obtener en: Supabase Dashboard > Project Settings > API > service_role
SUPABASE_SERVICE_ROLE_KEY=eyJ...
