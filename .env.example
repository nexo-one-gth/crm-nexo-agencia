# ─── Supabase ───────────────────────────────────────────────────────────────
# URL del proyecto (visible en: Supabase Dashboard > Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co

# Anon key (pública, va al bundle del cliente)
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# Service Role key — NUNCA exponer al cliente. Solo server-side.
# Obtener en: Supabase Dashboard > Project Settings > API > service_role
SUPABASE_SERVICE_ROLE_KEY=eyJ...
